{
  "version": 2,
  "builds": [
    {
      "src": "ems-frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ems-backend-jade-tau.vercel.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/ems-frontend/$1"
    }
  ]
}
